{
  "name": "samuisi.github.io",
  "type": "module",
  "version": "0.2.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "fonts:ui": "tsx scripts/fonts/subset-ui-font.ts",
    "build": "npm run fonts:ui && astro build && pagefind --site dist --output-subdir pagefind --root-selector main --exclude-selectors \"[data-pagefind-ignore]\"",
    "preview": "astro preview",
    "astro": "astro",
    "post:new": "tsx scripts/new-content.ts blog",
    "vibe:new": "tsx scripts/new-content.ts vibe",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "npm run lint && prettier --check ."
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@expressive-code/plugin-collapsible-sections": "^0.42.0",
    "@expressive-code/plugin-line-numbers": "^0.42.0",
    "@fontsource/maple-mono": "^5.2.6",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.4",
    "astro-expressive-code": "^0.42.0",
    "lucide-astro": "^0.556.0",
    "sharp": "^0.34.5",
    "smol-toml": "^1.6.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/compiler": "^4.0.0",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint-plugin-deprecation": "^3.0.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "eslint-plugin-deprecation": {
      "typescript": "$typescript"
    }
  }
}
